# ══════════════════════════════════════════════════════════════
#  .env.example  —  copy to .env.local for local development
#  All variables MUST be added to your Vercel project too:
#    vercel env add VARIABLE_NAME
#  or via the Vercel dashboard → Settings → Environment Variables
# ══════════════════════════════════════════════════════════════

# ── Required ───────────────────────────────────────────────────

# Your Telegram Bot Token from @BotFather
# Format: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_TOKEN=your_bot_token_here


# ── Recommended ────────────────────────────────────────────────

# Secret token Telegram sends on every webhook request so you
# can verify it's really Telegram calling your endpoint.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TELEGRAM_WEBHOOK_SECRET=your_random_secret_here

# Protects the /api/setup-webhook endpoint.
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ADMIN_TOKEN=your_admin_token_here

# Restricts which origins can call /api/chat (CORS).
# Use your production domain, e.g. https://yoursite.com
# Leave as * for development or if the API is served from the same origin.
ALLOWED_ORIGIN=*


# ── Optional: Your AI provider ─────────────────────────────────
# Add whichever key your existing bot uses:

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic / Claude
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# GEMINI_API_KEY=AIza...


# ── Optional: Vercel KV (persistent conversation history) ──────
# Created automatically when you link a KV store in the Vercel
# dashboard (Storage → Create → KV → Connect to project).
# You do NOT need to set these manually; Vercel sets them for you.

# KV_REST_API_URL=https://xxxx.upstash.io
# KV_REST_API_TOKEN=AXxx...
